[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    build,
    dist,
    *.egg-info
    .venv
    venv
    env
    .env
    .tox
    .pytest_cache
    .mypy_cache
    .coverage
    htmlcov

per-file-ignores =
    # Allow unused imports in __init__.py
    __init__.py: F401
    # Allow long lines in test files
    tests/*: E501
   
ignore =
    # Line break before/after binary operator
    W503,
    W504,
    # Multiple spaces around operators
    E221,
    E222,
    # Multiple spaces after ','
    E241,
    # Whitespace before ':' (needed for Black compatibility)
    E203

max-complexity = 12